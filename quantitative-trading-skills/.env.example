
# 量化交易技能套件 - 环境变量配置示例
# 复制此文件为 .env 并填入实际配置值
# 注意：.env 文件不应提交到版本控制，请确保已添加到 .gitignore

# ==================== 数据源配置 ====================

# Tushare Pro API Token (必选 - 用于Tushare数据源)
# 获取地址: https://tushare.pro/register
TUSHARE_TOKEN=

# XCSC Tushare Token (可选 - 财社聚宽版Tushare)
XCSC_TUSHARE_TOKEN=

# 掘金量化 API Token (可选 - 用于掘金数据源和回测)
# 获取地址: https://www.myquant.cn/
GM_TOKEN=

# ==================== 数据库配置 ====================

# 数据库类型: sqlite, mysql, postgresql (默认: sqlite)
DB_TYPE=sqlite

# MySQL/PostgreSQL 数据库连接配置 (仅当 DB_TYPE 不是 sqlite 时需要)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=a_share_data
DB_USER=
DB_PASSWORD=

# ==================== 存储配置 ====================

# 数据存储目录 (默认: ./data)
DATA_DIR=./data

# 因子数据存储目录 (默认: ./factor_data)
FACTOR_DATA_DIR=./factor_data

# 回测报告存储目录 (默认: ./reports)
REPORT_DIR=./reports

# ==================== 应用配置 ====================

# 默认数据后端: tushare, baostock, akshare, gm, xtquant (默认: tushare)
DATA_BACKEND=tushare

# 默认回测引擎: rqalpha, backtrader, gm (默认: rqalpha)
BACKTEST_ENGINE=rqalpha

# 技术分析库: pandas-ta, ta-lib (默认: pandas-ta)
TA_LIBRARY=pandas-ta

# 绘图后端: matplotlib, plotly (默认: matplotlib)
PLOT_BACKEND=matplotlib

# ==================== 日志配置 ====================

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL (默认: INFO)
LOG_LEVEL=INFO

# 日志文件路径 (可选)
LOG_FILE=

